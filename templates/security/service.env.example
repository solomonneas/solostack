# Copy this to a private local path such as:
#   $HOME/.config/agent-secrets/service.env
#
# Then lock it down:
#   chmod 600 $HOME/.config/agent-secrets/service.env
#
# Keep real values out of repos, logs, screenshots, memory, and public docs.

OPENCLAW_PROVIDER_TOKEN=<secret>
OPENCLAW_WEBHOOK_URL=<secret>
CONTENT_GUARD_POLICY=<local-policy-path>
SCRUB_RULES=<local-rules-path>
